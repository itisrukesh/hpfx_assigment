[
    {   
        "ruleid":"Rid001",
        "'description":"Rule to find mail with subject spam",
        "predicate": "All",
        "conditions": [
            {
                "field": "sender",
                "predicate": "Contains",
                "value": "photos@onedrive.com"
            },
            {
                "field": "subject",
                "predicate": "Does Not Contain",
                "value": "Spam"
            }
        ],
        "actions": [
            "mark_as_read",
            "move_to_label:STARRED"
        ]
    },
    {
